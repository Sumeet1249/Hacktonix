# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_DB=blindspot
POSTGRES_USER=blindspot
POSTGRES_PASSWORD=change_me_in_production

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── MinIO / S3 Storage ────────────────────────────────────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me_in_production
MINIO_BUCKET=blindspot
MINIO_ENDPOINT=http://minio:9000

# ── ML Settings ───────────────────────────────────────────────────────────────
# Set MOCK_ML=true to run fully without GPU (uses placeholder data)
# Set MOCK_ML=false to use real Stable Diffusion / Mask R-CNN (requires GPU)
MOCK_ML=true

# Number of images to generate per stressor category
IMAGES_PER_STRESSOR=8

# Use Blender for physics refinement (requires blender installed)
USE_BLENDER=false
BLENDER_PATH=/usr/bin/blender

# ── Frontend ─────────────────────────────────────────────────────────────────
REACT_APP_API_URL=http://localhost:8000

# ── HuggingFace (optional, for downloading models) ───────────────────────────
# HF_TOKEN=hf_your_token_here

# ── GPU Config (for real ML mode) ────────────────────────────────────────────
# CUDA_VISIBLE_DEVICES=0
